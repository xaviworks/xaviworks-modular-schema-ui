{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "xaviworks/modular-schema-ui",
    "description": "A modular, Blade-first schema-driven UI toolkit for Laravel.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Junn Xavier Adalid"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/database": "^13.0",
        "illuminate/pagination": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/view": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "XaviWorks\\ModularSchemaUi\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "XaviWorks\\ModularSchemaUi\\ModularSchemaUiServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
